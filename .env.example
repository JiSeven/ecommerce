# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
CLIENT_URL=http://localhost:5173

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce_secret
POSTGRES_DB=ecommerce_dev

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379

# ── pgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=9585e7b3f59f4b7abf13abb27eb00957046d21c7d4ce306188edd30956835fe4a7a9649c52c70b63c292e4ac61642e6b23ee8d16bf5f0ca9c2767ea3e58dca5e
JWT_REFRESH_SECRET=73bb7e5b0ec945a2d6984362abb70529f77da5ad6404ffaa1c450a41211d71d2aa996b3d7cfe48450b69621b5610e171acff36d4d85e8ddff458d63f982d7449
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/applications/new
# Callback URL: http://localhost:3000/api/v1/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use TEST keys (sk_test_ / pk_test_) in development
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
# Get webhook secret by running: stripe listen --forward-to localhost:3000/api/v1/payments/webhook
STRIPE_WEBHOOK_SECRET=whsec_

# ── Email ─────────────────────────────────────────────────────────────────────
# Points to Mailpit in development — catches all mail, nothing is sent for real
# View caught emails at http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@ecommerce.dev

# ── Observability ─────────────────────────────────────────────────────────────
# Optional — leave empty to disable Sentry in development
SENTRY_DSN=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173
