{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "feat",
        "fix",
        "refactor",
        "perf",
        "test",
        "chore",
        "docs",
        "ci",
        "revert"
      ]
    ],
    "scope-enum": [
      1,
      "always",
      [
        "auth",
        "users",
        "products",
        "cart",
        "orders",
        "payments",
        "admin",
        "graphql",
        "jobs",
        "database",
        "config",
        "docker",
        "ci",
        "deps",
        "types"
      ]
    ],
    "subject-case": [2, "always", "lower-case"],
    "subject-max-length": [2, "always", 72],
    "body-max-line-length": [2, "always", 100]
  }
}
